			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui",
				"--",
				"tests/edit-action-workspace.spec.ts"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "npm build",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Fix esbuild and build",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/fix-esbuild.js",
				"&&",
				"npm",
				"run",
				"build"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Esbuild 2",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/fix-esbuild-2.js",
				"&&",
				"npm",
				"run",
				"build"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Playwright tests 4",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Test main view",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui",
				"--",
				"tests/main-view.spec.ts"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Fix main view",
			"type": "shell",
			"command": "node",
			"args": [
