			"command": "npm",
			"args": [
				"run",
				"test:ui",
				"--",
				"tests/jobs-view.spec.ts"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "npm build 2",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Full E2E",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Full Unit tests",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:unit"
			],
			"isBackground": false,
			"group": "test"
		}
	],
	"inputs": [
		{
			"id": "releaseType",
			"type": "pickString",
			"description": "Select the version bump for the release workflow",
			"options": [
				"patch",
				"minor",
				"major"
			],
			"default": "patch"
		}
	]
}