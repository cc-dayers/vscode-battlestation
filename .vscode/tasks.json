			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:unit"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Fix Unit tests",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/fix-unit-tests.js"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Check Types 9",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Select String",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-Command",
				"Select-String -Pattern 'const config: Config = {' 'src/test/suite/configLifecycle.test.ts' -Context 0,10"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Unit tests 2",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:unit"
			],
			"isBackground": false,
			"group": "test"
		},
		{
