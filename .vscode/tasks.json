			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Playwright tests 5",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "fix main view 2",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/fix-main-view-2.js"
			],
			"isBackground": false,
			"group": "test"
		},
