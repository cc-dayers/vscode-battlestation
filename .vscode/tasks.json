			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Playwright tests 2",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Fix jobs view tests",
			"type": "shell",
			"command": "node",
			"args": [
