			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Playwright tests 3",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:ui"
			],
			"isBackground": false,
			"group": "test"
		},
