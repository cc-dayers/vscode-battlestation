{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": {
				"owner": "esbuild",
				"pattern": {
					"regexp": "^✘ \\[ERROR\\] (.+)$",
					"message": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\] build started",
					"endsPattern": "^\\[watch\\] build finished"
				}
			}
		},
		{
			"type": "npm",
			"script": "test:ui-server",
			"label": "Serve UI (localhost:3000)",
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		},
		{
			"label": "Release: Version, tag, and publish VSIX",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"npm run release:run -- ${input:releaseType}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"problemMatcher": []
		},
		{
			"label": "Clean Extension",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/clean-extension-cmds.js"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Type Check",
			"type": "shell",
			"command": "npx tsc",
			"args": [
				"--noEmit"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "NPM Check Types",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Clean Extension part 4",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/clean-extension-cmds-4.js"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "NPM Check Types 2",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Rebuild Extension",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/rebuild-extension.js"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Check types 3",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Lint",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Delete files",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"del /f /q src\\battlesView.ts src\\battleTestPanel.ts src\\types.ts src\\services\\battleProviderService.ts src\\services\\agentService.ts src\\services\\managedWorktreeLanguageModelToolService.ts src\\services\\orchestrationRoutingService.ts src\\services\\orchestrationStateService.ts src\\services\\orchestrationStateTypes.ts src\\services\\toolLoopService.ts src\\services\\worktreeService.ts src\\utils\\orchestrationRadar.ts src\\utils\\workflows.ts src\\utils\\battleProviderConfig.ts src\\utils\\battleProviderPayload.ts"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Restore types",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"git checkout src/types.ts"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Clean types",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/clean-types.js"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Check Types 4",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Check types 5",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Check Types 6",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Check types 7",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Check types 8",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"check-types"
			],
			"isBackground": false,
			"group": "test"
		},
		{
